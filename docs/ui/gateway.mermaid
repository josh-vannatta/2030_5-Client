graph LR
    classDef header fill:#1e293b,color:#fff,stroke:#0f172a
    classDef good fill:#dcfce7,stroke:#16a34a,color:#065f46
    classDef warn fill:#fef3c7,stroke:#d97706,color:#78350f

    subgraph CLIENT["2030.5 Gateway Client"]
        H["DER-01 | Connected"]:::header
    end

    subgraph TELE["Telemetry"]
        T1["P: 5.20 kW"]
        T2["Q: -1.20 kVAR"]
        T3["V: 240.1 V"]
        T4["I: 21.5 A"]
        T5["PF: 0.980"]
        T6["SOC: 67.5 %"]
        T1 --> T2 --> T3 --> T4 --> T5 --> T6
    end

    subgraph STATE["2030.5 State"]
        S1["DCAP ✓"]
        S2["Time ✓"]
        S3["EndDevice ✓"]
        S4["FSA / DERP ✓"]
        S5["Subscribed ✓"]
        S1 --> S2 --> S3 --> S4 --> S5
    end

    subgraph CTRL["Active Control"]
        C1["MRID: ctrl-123"]
        C2["Mode: Fixed VAR"]
        C3["Setpoint: 2000 VAR"]
        C4["Status: ACTIVE"]:::warn
        C1 --> C2 --> C3 --> C4
    end

    subgraph REG["Registers"]
        R1["40083 → 5200 (P)"]
        R2["40084 → -1200 (Q)"]
        R3["40076 → 2401 (V)"]
        R4["40111 → 2000 (override)"]
        R1 --> R2 --> R3 --> R4
    end

    subgraph HEALTH["Health"]
        H1["Runtime: Healthy"]:::good
        H2["Adapter: Connected"]
        H3["Poll: 30s"]
        H4["Errors: None"]
        H1 --> H2 --> H3 --> H4
    end

    CLIENT --> TELE --> STATE --> CTRL --> REG --> HEALTH