graph LR
    classDef header fill:#1e293b,color:#fff,stroke:#0f172a
    classDef good fill:#dcfce7,stroke:#16a34a,color:#065f46
    classDef warn fill:#fef3c7,stroke:#d97706,color:#78350f

    subgraph DEVICE["Test Field Device"]
        H["Mock Inverter | Connected"]:::header
    end

    subgraph STATUS["Master Status"]
        S1["Modbus: Connected"]:::good
        S2["DNP3: Idle"]
        S3["Last Cmd: 15:33:01"]
        S4["Latency: 12 ms"]
        S1 --> S2 --> S3 --> S4
    end

    subgraph ELEC["Electrical State"]
        E1["P: 5.18 kW"]
        E2["Q: 1.95 kVAR"]
        E3["V: 239.8 V"]
        E4["I: 21.3 A"]
        E5["PF: 0.965"]
        E1 --> E2 --> E3 --> E4 --> E5
    end

    subgraph MODE["Device Mode"]
        M1["State: Connected"]
        M2["Control: External"]:::warn
        M3["Local Control: Disabled"]
        M1 --> M2 --> M3
    end

    subgraph REGS["Registers"]
        R1["40083 → 5180"]
        R2["40084 → 1950"]
        R3["40111 → 2000"]
        R4["40104 → 1"]
        R1 --> R2 --> R3 --> R4
    end

    subgraph LOGS["Command History"]
        L1["write 40111 = 2000"]
        L2["write 40104 = 1"]
        L3["source: gateway"]
        L4["mrid: ctrl-123"]
        L1 --> L2 --> L3 --> L4
    end

    DEVICE --> STATUS --> ELEC --> MODE --> REGS --> LOGS